{
  "name": "costmcp",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:migrate": "npx supabase@latest db push",
    "db:types": "node scripts/generate-db-types.mjs",
    "seed:test": "node --env-file=.env packages/db/scripts/seed-test-account.mjs",
    "mcp:dev": "node --env-file=.env packages/mcp-server/node_modules/tsx/dist/cli.mjs watch packages/mcp-server/src/index.ts"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
