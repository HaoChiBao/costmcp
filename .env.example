# CostMCP — shared local env (copy to `.env` at repo root)
# Dashboard: https://supabase.com/dashboard/project/bylrekkhwcwosdmcgfsg/settings/api
SUPABASE_URL=https://bylrekkhwcwosdmcgfsg.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API (apps/api)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# OAuth issuer (authorization server) — production: https://api.costmcp.com
COSTMCP_PUBLIC_URL=http://localhost:3000

# Dedicated MCP URL for AI agents — production: https://mcp.costmcp.com
COSTMCP_MCP_URL=http://localhost:3000/api/mcp
NEXT_PUBLIC_MCP_URL=http://localhost:3000/api/mcp

# Web dashboard origin — where OAuth login + consent happens.
NEXT_PUBLIC_WEB_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3001

# Web (apps/web)
NEXT_PUBLIC_SUPABASE_URL=https://bylrekkhwcwosdmcgfsg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Client ingest key (SDK / MCP / pipelines)
COSTMCP_API_URL=http://localhost:3000
COSTMCP_API_KEY=cmcp_live_your_key_here
# Production: leave unset / false. Local/dev env key bypass is on when NODE_ENV !== production.
# COSTMCP_ALLOW_ENV_API_KEY=true

